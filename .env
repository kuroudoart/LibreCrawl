# LibreCrawl Docker 環境設定

# アプリケーションのホストバインド
# - 127.0.0.1 = localhost のみ（ローカル開発用）
# - 0.0.0.0 = 全インターフェース（本番環境、ネットワークからアクセス可能）
HOST_BINDING=127.0.0.1

# ローカルモード - 管理者アクセスで自動ログイン、レート制限なし
# ローカル開発時は "true"、本番環境では "false" に設定
LOCAL_MODE=true

# ユーザー登録を無効にする
# 新規ユーザーの登録を防ぐには "true" に設定
# 既存ユーザーのみにしたい本番環境で便利
REGISTRATION_DISABLED=false

# 確認メール用のメール設定
# SMTP サーバー設定
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@librecrawl.com
SMTP_FROM_NAME=LibreCrawl

# メール内リンクのベース URL（確認リンクの生成に使用）
MAIN_APP_URL=https://crawl.librecrawl.com
WORKSHOP_APP_URL=https://workshop.librecrawl.com
